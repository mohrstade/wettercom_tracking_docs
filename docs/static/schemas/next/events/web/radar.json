{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tracking.wetter.com/schemas/events/web/radar.json",
  "title": "radar",
  "description": "Covers radar events",
  "x-tracking-targets": ["web-datalayer-js"],
  "type": "object",
  "properties": {
    "$schema": {
      "description": "Defines the structure of the event. This can be used to validate an event against the schema provided.",
      "const": "https://tracking.wetter.com/schemas/events/web/radar.json",
      "type": "string"
    },
    "event": {
      "type": "string",
      "const": "radar",
      "description": "Events covers the Regenradar feature"
    },
    "radarAction": {
      "type": "string",
      "description": "Type of action of the Regenradar screen",
      "examples": ["Webview NextGen"]
    },
    "radarLabel": {
      "type": "string",
      "description": "Describes the layout of the Regenradar feature",
      "examples": ["initial_map_style_satellite"]
    }
  },
  "required": ["$schema", "event"]
}
